# ============================================================
#  THUMBNAIL SAAS - 환경 변수 템플릿
#  이 파일을 복사해서 .env 로 이름 바꿔서 사용
#  키가 비어있으면 자동으로 mock(로컬 합성) 모드로 동작
# ============================================================

# ---- 서버 설정 ----
HOST=127.0.0.1
PORT=8000
DEBUG=true

# ---- AI Provider 선택 ----
# 가능값: mock | openai | stability | gemini
# mock = API 키 없이 로컬 그라데이션/패턴 배경 생성
BG_PROVIDER=mock
TEXT_PROVIDER=mock
QC_PROVIDER=mock

# ---- 누끼 모델 선택 ----
# 가능값: u2net | u2netp | isnet-general-use | birefnet-general
# 일반 제품: u2net (기본/추천)
# 사람/패션: u2net-human-seg
# 빠른 처리: u2netp
MATTING_MODEL=u2net

# ---- AI Provider 키 (필요시만) ----
OPENAI_API_KEY=
STABILITY_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ---- 저장소 ----
WORKSPACE_DIR=./workspace
MAX_UPLOAD_MB=20

# ---- 생성 옵션 ----
# 한 번에 생성할 썸네일 개수 (A/B 테스트용)
DEFAULT_VARIANTS=4
# 출력 해상도
OUTPUT_SIZE=1000
